# GitHub Talent Hunt Agent example environment variables
# Copy this file to .env and fill in the values locally.

# --- GitHub API ---
# Personal access token with public repo access. Leave empty for anonymous GitHub rate limits.
GITHUB_TOKEN=

# --- Flask / runtime ---
APP_ENV=production
HOST=0.0.0.0
PORT=8000
CORS_ALLOWED_ORIGINS=*
SECRET_KEY=change-me-to-a-long-random-random-string

# --- Request limits ---
MAX_SEARCH_SIZE=100
MAX_RESULTS=50
MAX_REPOS_PER_USER=20
SCRAPER_MAX_WORKERS=8
# Scrape GitHub achievement badges (Pull Shark, Starstruck, ...) for the
# shortlist. They are not in the API, so this adds one HTML request per
# shortlisted candidate. Set to false to disable.
FETCH_ACHIEVEMENTS=true

# --- Rate limiting ---
RATELIMIT_STORAGE_URI=memory://
RATELIMIT_DEFAULT=60 per minute
RATELIMIT_SEARCH=10 per minute

# --- LLM provider ---
# Options: none | openai | groq | bedrock
LLM_PROVIDER=none
LLM_EVAL_TOP_K=12
# Rate-limit controls. On token-per-minute-limited tiers (e.g. Groq free = 8000
# TPM) lower LLM_MAX_CONCURRENCY to 1 and LLM_EVAL_TOP_K to ~6 to avoid 429s.
LLM_MAX_CONCURRENCY=2
LLM_MAX_RETRIES=5
LLM_EVAL_MAX_TOKENS=500

# OpenAI settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# Groq settings (OpenAI-compatible; serves gpt-oss-20b and other open models)
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Reasoning budget for gpt-oss: low | medium | high
GROQ_REASONING_EFFORT=low

# AWS Bedrock settings
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

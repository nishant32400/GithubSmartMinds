# GitHub Talent Hunt Agent example environment variables
# Copy this file to .env and fill in the values locally.

# --- GitHub API ---
# Personal access token with public repo access. Leave empty for anonymous GitHub rate limits.
GITHUB_TOKEN=

# --- Flask / runtime ---
APP_ENV=production
HOST=0.0.0.0
PORT=8000
CORS_ALLOWED_ORIGINS=*
SECRET_KEY=change-me-to-a-long-random-random-string

# --- Request limits ---
MAX_SEARCH_SIZE=100
MAX_RESULTS=50
MAX_REPOS_PER_USER=20
SCRAPER_MAX_WORKERS=8

# --- Rate limiting ---
RATELIMIT_STORAGE_URI=memory://
RATELIMIT_DEFAULT=60 per minute
RATELIMIT_SEARCH=10 per minute

# --- LLM provider ---
# Options: none | openai | bedrock
LLM_PROVIDER=none
LLM_EVAL_TOP_K=12

# OpenAI settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# AWS Bedrock settings
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
